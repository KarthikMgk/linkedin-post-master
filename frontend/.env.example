# Backend API URL — set this in Vercel environment dashboard for production.
# In development, CRA's proxy (package.json "proxy") handles /api/* requests
# so this variable is not required locally.
REACT_APP_API_URL=https://your-backend.up.railway.app

# Google OAuth Client ID — MUST match GOOGLE_CLIENT_ID on the backend.
# Get from: Google Cloud Console → APIs & Services → Credentials
# Add to Vercel environment dashboard for production.
# Create frontend/.env.local for local development (never commit this file).
REACT_APP_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
